# ByBit V5 API credentials. Issue a READ-ONLY key at https://www.bybit.com/app/user/api-management
# Never commit your real key/secret.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Optional: hit ByBit testnet (sandbox) instead of mainnet. Default: 0 (mainnet).
# BYBIT_TESTNET=0

# Optional: HMAC signature receive window in milliseconds. Default: 5000.
# BYBIT_RECV_WINDOW=5000

# Optional: HTTP request timeout in seconds. Default: 30.
# BYBIT_TIMEOUT=30

# Optional: log level (DEBUG | INFO | WARNING | ERROR). Default: INFO. Logs go to stderr only.
# BYBIT_LOG_LEVEL=INFO

# Optional: REST base URL override. Almost never needs changing.
# BYBIT_API_BASE=https://api.bybit.com
