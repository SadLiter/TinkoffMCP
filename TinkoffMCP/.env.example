# T-Invest read-only API token. Generate at https://www.tbank.ru/invest/settings/api/
# Issue a READ-ONLY token (нет права на торговлю). Never commit your real token.
INVEST_TOKEN=

# Optional: path to a CA bundle that trusts Russian Trusted Root CA.
# Leave empty to use the bundled certs/russian_trusted_ca.pem.
# TBANK_CA_BUNDLE=

# Optional: request timeout in seconds (default: 30)
# TBANK_TIMEOUT=30

# Optional: log level (DEBUG | INFO | WARNING | ERROR). Default: INFO. Logs go to stderr only.
# TBANK_LOG_LEVEL=INFO

# Optional: REST base URL. Almost never needs changing.
# Only override to a trusted endpoint — server rejects anything that is not
# https:// and warns whenever you point it away from the T-Bank default.
# TBANK_API_BASE=https://invest-public-api.tbank.ru/rest
